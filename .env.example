# Copy to .env for local dev, or to /etc/school-management/env for production.
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"

# --- Required in production ---
SECRET_KEY=change_this_to_a_long_random_string
FLASK_ENV=production
PRODUCTION=1

# --- Database ---
# Default: SQLite in instance/keeptrack_full.db (fine for small/medium schools)
# DATABASE_URL=sqlite:////var/www/school-management/instance/keeptrack_full.db
# For larger deployments use PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://schooluser:password@127.0.0.1:5432/school_db
#
# On VPS first install: FRESH_DATABASE=1 wipes instance/*.db and creates empty tables.
# Your local development database is gitignored and never pushed to GitHub.
# FRESH_DATABASE=1

# --- Server bind (Gunicorn reads GUNICORN_BIND; app uses PORT for docs) ---
PORT=8000
GUNICORN_BIND=127.0.0.1:8000
WEB_CONCURRENCY=1
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=120

# --- HTTPS behind Nginx ---
SESSION_COOKIE_SECURE=true
PROXY_FIX_HOPS=1

# --- Uploads ---
MAX_UPLOAD_MB=16
