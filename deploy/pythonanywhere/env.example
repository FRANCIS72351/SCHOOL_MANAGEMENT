# Copy to /home/YOUR_USERNAME/SCHOOL_MANAGEMENT/.env on PythonAnywhere
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change_this_to_a_long_random_string
FLASK_ENV=production
PRODUCTION=1

# SQLite (default). Path is optional — app uses instance/keeptrack_full.db automatically.
# DATABASE_URL=sqlite:////home/YOUR_USERNAME/SCHOOL_MANAGEMENT/instance/keeptrack_full.db

SESSION_COOKIE_SECURE=true
WTF_CSRF_SSL_STRICT=true

# Fresh empty database on first setup (local dev DB is not in git)
FRESH_DATABASE=1

# Master admin created on first setup
ADMIN_EMAIL=admin@school.com
ADMIN_NAME=School Administrator
ADMIN_PASSWORD=set_a_strong_password_here
