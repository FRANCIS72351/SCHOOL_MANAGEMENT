# Production environment — copy to /etc/school-management/env on Linux VPS
# chmod 600 /etc/school-management/env

SECRET_KEY=REPLACE_WITH_python3_-c_import_secrets_print_secrets_token_hex_32
FLASK_ENV=production
PRODUCTION=1

DATABASE_URL=sqlite:////var/www/school-management/instance/keeptrack_full.db

# --- Fresh install: empty database on server (your local .db is NOT uploaded via git) ---
FRESH_DATABASE=1
ADMIN_EMAIL=admin@school.com
ADMIN_NAME=School Administrator
ADMIN_PASSWORD=set_a_strong_password_here

GUNICORN_BIND=127.0.0.1:8000
WEB_CONCURRENCY=1
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=120
GUNICORN_PRELOAD=true

SESSION_COOKIE_SECURE=true
PROXY_FIX_HOPS=1
MAX_UPLOAD_MB=16
